# SAP BDC Snowflake MCP Server — configuration
#
# Auth option A (recommended): a named connection from ~/.snowflake/connections.toml
SNOWFLAKE_CONNECTION=dfreriksdemo

# Auth option B (discrete): uncomment and set these instead of SNOWFLAKE_CONNECTION
# SNOWFLAKE_ACCOUNT=myorg-myaccount
# SNOWFLAKE_USER=my_user
# SNOWFLAKE_ROLE=ACCOUNTADMIN
# SNOWFLAKE_WAREHOUSE=my_wh
# SNOWFLAKE_AUTHENTICATOR=externalbrowser        # or set SNOWFLAKE_PASSWORD / SNOWFLAKE_PRIVATE_KEY_PATH
# SNOWFLAKE_PASSWORD=...
# SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/keys/rsa_key.p8

# SAP BDC Connect zero-copy connector
BDC_CONNECTOR_NAME=SAP_BDC_CONNECT_ZC
BDC_CONNECTOR_DATABASE=SAP_BDC_CONNECT
BDC_CONNECTOR_SCHEMA=PUBLIC

# Optional
LOG_LEVEL=INFO
